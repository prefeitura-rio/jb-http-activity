{
  "name": "jb-http-activity",
  "version": "1.0.0",
  "private": true,
  "description": "Custom Activity genérica para chamadas HTTP no Journey Builder do Salesforce Marketing Cloud",
  "scripts": {
    "start": "npm run build && npx tsc && node server/index.js",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "test": "mocha --require ts-node/register test/**/*.test.ts --timeout 30000",
    "typecheck": "tsc --noEmit && vue-tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^7.0.0",
    "axios": "^1.7.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "form-data": "4.0.6",
    "jsonwebtoken": "^9.0.0",
    "postmonger": "^0.0.16",
    "vue": "^3.5.35"
  },
  "overrides": {
    "form-data": "4.0.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "mocha": "^10.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^5.4.0",
    "vue-tsc": "^3.3.6"
  }
}
