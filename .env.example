JWT_SECRET=seu-app-signing-secret-aqui
PORT=3000
NODE_ENV=development
BIGQUERY_DATASET=jb_http_activity
BIGQUERY_TABLE=logs
UI_BASE_PATH=/
VITE_BASE_PATH=/
# Credenciais de integracao Server-to-Server com a SFMC (deployment-level, nunca por activity)
SFMC_AUTH_URI=https://seu-subdominio.auth.marketingcloudapis.com
SFMC_CLIENT_ID=seu-client-id
SFMC_CLIENT_SECRET=seu-client-secret
# deExternalKey e deKeyField (qual DE e qual campo-chave) sao configurados
# por activity, na aba Request da tela de configuracao no Journey Builder.
